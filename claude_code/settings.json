{
  "apiKeyHelper": "$HOME/.claude/anthropic_key.sh",
  "enabledPlugins": {
    "swift-lsp@claude-plugins-official": true
  },
  "env": {
    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1"
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "bash '/Users/pere.bohigas/.claude/hooks/herdr-agent-state.sh' session",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "*"
      }
    ]
  },
  "permissions": {
    "allow": [
      "mcp__pencil"
    ]
  },
  "theme": "dark"
}