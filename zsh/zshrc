# Use anonymous function encapsulation only for scoping purposes
# see: https://stackoverflow.com/a/13670749
# Load custom functions
() {
	# Add directories with custom functions
	if [[ -d "$HOME/.config/zsh/bash_functions" ]] && (( $+commands[bash] )); then
		fpath=("$HOME/.config/zsh/bash_functions" $fpath)
	else
		print "File with custom Bash functions not found in '$HOME/.config/zsh/bash_functions/' or Bash not available in the system" >&2
	fi

	if [[ -d "$HOME/.config/zsh/zsh_functions" ]]; then
		fpath=("$HOME/.config/zsh/zsh_functions" $fpath)
	else
		print "File with custom Zsh functions not found in '$HOME/.config/zsh/zsh_functions/'" >&2
	fi

	local custom_functions_to_load=(
		audio_fix_crackling_noise
		git_change_author
		git_change_timestamp
		git_clone_worktrees
		git_multiple_pull
		gpg_export_key
		gpg_import_key
		latex_update
		ssh_add_identities
		ssh_copy_key
		ssh_generate_key
		teams_clean_cache
		xcode_projects_list
		xcode_remove_derived_data
		zellij_attach_interactive
	)

	local custom_function

	for custom_function in $custom_functions_to_load; do
		local is_function_in_fpath=( $^fpath/$custom_function(N) )

		if (( $#is_function_in_fpath )); then
			autoload -Uz $custom_function
		else
			print "warning: $custom_function not found in fpath" >&2
		fi
	done
}

