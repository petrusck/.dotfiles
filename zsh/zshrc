## Interactive tool configuration

# Preview command shared by FZF and Skim:
#   - directories: tree (fallback: ls)
#   - binary files: file
#   - text files:   bat  (fallback: cat)
PREVIEW_COMMAND="
	if [ -d {} ]; then
		command -v tree >/dev/null && tree -C -L 2 {} || ls -la {}
	elif file --mime {} | grep -q binary; then
		file {}
	else
		command -v bat >/dev/null && bat --style=numbers --color=always --line-range=:500 {} || cat {}
	fi
"

