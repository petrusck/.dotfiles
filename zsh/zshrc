# PostgreSQL binaries (pick the highest installed version)
function() {
	local pg_dir

	pg_dir=(/opt/homebrew/opt/postgresql@*(nN[-1]))

	if [[ -n "$pg_dir" && -d "$pg_dir/bin" ]]; then
		PATH="$PATH:$pg_dir/bin"
	elif [[ -d /run/current-system/sw/bin ]] && command -v psql &>/dev/null; then
		: # already in PATH via Nix
	fi
}

