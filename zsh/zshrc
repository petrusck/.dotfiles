## Zsh options

# Enable extended globbing feature (required by compinit cache check glob qualifier #qN.mh+24)
setopt EXTENDED_GLOB

autoload -Uz compinit

# Build/refresh the completion cache.
#   - Fast path (compinit -C): skip the freshness scan + compaudit security
#     check; just load the existing dump. Taken on almost every startup.
#   - Slow path (compinit): full rescan + compaudit. Taken when the dump is
#     missing/empty or older than 24h. `touch` bumps the dump mtime so the 24h
#     guard actually resets -- compinit does NOT rewrite the dump when nothing
#     changed, which previously pinned every startup to the slow path.
#   - Recompile to .zwc only when the dump changed (or .zwc is missing).
() {
	local zcd=${ZDOTDIR:-$HOME}/.zcompdump

	if [[ ! -s $zcd || -n $zcd(#qN.mh+24) ]]; then
		compinit -d "$zcd"
		[[ -s "$zcd" ]] && touch "$zcd"
	else
		compinit -C -d "$zcd"
	fi

	if [[ -s "$zcd" && ( ! -f "$zcd.zwc" || "$zcd" -nt "$zcd.zwc" ) ]]; then
		zcompile -R "$zcd" 2>/dev/null &!
	fi
}

