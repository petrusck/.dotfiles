# zsh-vi-mode: always start in insert mode for predictable behavior
function zvm_config() {
	ZVM_LINE_INIT_MODE=$ZVM_MODE_INSERT
	ZVM_SYSTEM_CLIPBOARD_ENABLED=true
}

# Set ctrl + y for accepting the proposed suggestion of autosuggestions (as the vim/nvim default keybinding)
# Set ctrl + k for browsing history backward
# Set ctrl + j for browsing history forward
# Must be set inside zvm_after_init to survive zsh-vi-mode keymap resets
# see: https://github.com/jeffreytse/zsh-vi-mode#execute-extra-commands
function zvm_after_init() {
	# Re-apply fzf's keymap bindings (^R/^T/Alt-C), which zsh-vi-mode resets on
	# its deferred init. Sourcing key-bindings.zsh again is idempotent.
	[[ -f $_ZSH_FZF_KEYBINDINGS ]] && source "$_ZSH_FZF_KEYBINDINGS"

	bindkey "^y" autosuggest-accept
	bindkey "^k" history-search-backward
	bindkey "^j" history-search-forward
}

