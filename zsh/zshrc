## Plugins

# Use anonymous function encapsulation only for scoping purposes
# see: https://stackoverflow.com/a/13670749
# Dynamically detects Nix vs Homebrew plugin paths
() {
	local nix_sw="/run/current-system/sw"
	local nix_share="$nix_sw/share"
	local brew_share="$HOMEBREW_PREFIX/share"
	local brew_opt="$HOMEBREW_PREFIX/opt"

	# Detect package source: prefer Nix if available, fall back to Homebrew
	local share opt

	if [[ -d "$nix_share/zsh-autosuggestions" ]]; then
		share="$nix_share"
		opt="$nix_sw"
	elif [[ -n "$HOMEBREW_PREFIX" ]]; then
		share="$brew_share"
		opt="$brew_opt"
	fi

	# Re-sourced by zvm_after_init so fzf's keymap bindings survive zsh-vi-mode's reset
	typeset -g _ZSH_FZF_KEYBINDINGS="$opt/fzf/shell/key-bindings.zsh"

	typeset -A plugins=(
		[vi_mode]="$opt/zsh-vi-mode/share/zsh-vi-mode/zsh-vi-mode.plugin.zsh"
		[fzf_completion]="$opt/fzf/shell/completion.zsh"
		[fzf_key_bindings]="$opt/fzf/shell/key-bindings.zsh"
		[autosuggestions]="$share/zsh-autosuggestions/zsh-autosuggestions.zsh"
		[syntax_highlighting]="$share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"
	)

	# Source in a FIXED order (associative-array iteration order is undefined in
	# zsh). zsh-syntax-highlighting MUST be last so it can wrap every ZLE widget
	# defined by the preceding plugins; zsh-autosuggestions must come right before it.
	local key
	for key in vi_mode fzf_completion fzf_key_bindings autosuggestions syntax_highlighting; do
		# fzf's shell scripts restore the 'zle' option on exit, which fails
		# harmlessly ("can't change option: zle") in an interactive shell without a
		# controlling tty (e.g. `zsh -i` spawned by an IDE/agent). Their widgets need
		# a real line editor anyway, so skip them when stdin isn't a terminal.
		[[ $key == fzf_* && ! -t 0 ]] && continue
		[[ -f $plugins[$key] ]] && source "$plugins[$key]" \
			|| echo "Plugin $key not loaded, file '$plugins[$key]' not found!"
	done
}

