#!/bin/zsh

## Navigation

# cd
alias .="cd ."
alias ..="cd .."

# ls
if (( $+commands[eza] )); then
	# Show files and directories
	alias l="eza -l --git --group-directories-first --icons --no-user"
	# Show files and directories sorted by recently modified
	alias ld="eza -l --git --group-directories-first --icons --no-user --sort=modified -r"
	# Show files and directories including hidden ones
	alias ll="eza -al --git --group-directories-first --icons --no-user"
	# Show files and directories including hidden ones sorted by recently modified
	alias lld="eza -al --git --group-directories-first --icons --no-user --sort=modified -r"
	# Show files and directories including hidden ones in a three level depth
	alias lll="eza -alT --git --group-directories-first --icons --level=3 --no-user"
	# Show files and directories including hidden ones in a three level depth sorted by recently modified
	alias llld="eza -alT --git --group-directories-first --icons --level=3 --no-user --sort=modified -r"
else
	# Show files and directories
	alias l="ls -FGhl"
	# Show files and directories sorted by recently modified
	alias ld="ls -FGhlt"
	# Show files and directories including hidden ones
	alias ll="ls -aFGhl"
	# Show files and directories including hidden ones sorted by recently modified
	alias lld="ls -aFGhlt"
fi

# macOS directories
alias desktop="cd $HOME/Desktop/"
alias downloads="cd $HOME/Downloads/"

## Applications

# Lazygit
(( $+commands[lazygit] )) && alias lg="lazygit"

# Ncspot
(( $+commands[spotify_player] )) && alias spotify="spotify_player"

# Fabric
(( $+commands[fabric-ai] )) && alias fabric='fabric-ai'

# Zellij (session-only persistence layer; see zellij/keybindings.md)
if (( $+commands[zellij] )); then
	# Attach to a session, creating it if it does not exist
	alias za="zellij attach -c"
	# Interactively select a session to attach to (using skim for the selection, falling back to a builtin select menu).
	# Backed by the zellij_attach_interactive autoloaded function (see zshrc), which resolves lazily on first call.
	alias zai="zellij_attach_interactive"
	# List active sessions
	alias zl="zellij list-sessions"
	# Detach from the current session (run inside Zellij)
	alias zd="zellij action detach"
	# Kill a named session
	alias zk="zellij kill-session"
	# Kill every session
	alias zka="zellij kill-all-sessions"
fi

# Herdr (agent-aware persistence layer; see herdr/keybindings.md)
if (( $+commands[herdr] )); then
	# Launch or attach to the default persistent session
	alias hh="herdr"
	# Attach to a named session, creating it if it does not exist
	alias ha="herdr session attach"
	# List named sessions
	alias hl="herdr session list"
	# Show local client + running server status
	alias hs="herdr status"
	# Stop the running server (kills all panes)
	alias hk="herdr server stop"
fi

# Xcode
alias derived_data="cd $HOME/Library/Developer/Xcode/DerivedData/"

## Suffix Aliases
alias -s md="bat"
