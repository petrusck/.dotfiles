#!/usr/bin/env bash
#
# Pre-commit hook: scan staged changes for secrets with Gitleaks, then
# chain to any repository-local pre-commit hook.
#
# This single script is used in two ways:
#   1. The dotfiles repo, via a local  core.hooksPath -> git/hooks/.
#   2. Every other repo, via a global  core.hooksPath -> git/global_hooks/
#      (whose pre-commit is a symlink to this file).
#
# Because a global core.hooksPath overrides a repo's .git/hooks/, we
# explicitly chain to the repo-local pre-commit hook (if any) so that
# hand-written local hooks are preserved. Repos that manage their own
# hooks via a *local* core.hooksPath (Husky, lefthook, pre-commit, ...)
# are unaffected, since a local core.hooksPath takes precedence over the
# global one and this script never runs for them.
#
# git-crypt encrypted files (*.secret.*) are already encrypted in the
# staging area via the clean filter, so gitleaks only sees binary blobs
# for those files -- no special handling needed.
#
# To bypass: SKIP=gitleaks git commit -m "message"
#

# --- Secret scanning (gitleaks) ---

if [[ "$SKIP" == *"gitleaks"* ]]; then
	echo "gitleaks: skipped (SKIP=gitleaks)"
elif ! command -v gitleaks &>/dev/null; then
	echo ""
	echo "WARNING: gitleaks is not installed."
	echo ""
	echo "  Gitleaks scans your code for hardcoded secrets (API keys,"
	echo "  passwords, tokens, etc.) before they are committed."
	echo ""
	echo "  Install it with:"
	echo "    brew install gitleaks"
	echo ""
	echo "  More info: https://github.com/gitleaks/gitleaks"
	echo ""
else
	# Scan staged changes; abort the commit if any secret is found.
	gitleaks git --staged --no-banner --redact -v || exit 1
fi

# --- Chain to the repository-local pre-commit hook (if present) ---
#
# Use --git-dir (not --git-path hooks, which honors core.hooksPath) so we
# always target the repo's real .git/hooks/ directory. The -ef guard
# avoids re-executing this same script.

local_hook="$(git rev-parse --git-dir)/hooks/pre-commit"
if [[ -x "$local_hook" && ! "$local_hook" -ef "$0" ]]; then
	exec "$local_hook" "$@"
fi

exit 0
