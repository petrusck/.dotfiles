// Zellij Configuration
// ====================
//
// Vim-philosophy keybindings designed for:
//   - EurKEY keyboard layout (all Alt/Opt combos reserved for European chars)
//   - Amethyst window manager (Opt+Cmd / Opt+Cmd+Shift reserved)
//   - macOS system shortcuts (Ctrl+Arrow, Ctrl+Space reserved)
//
// See keybindings.md for the full reference and design rationale.
// See migration_guide.md for transitioning from Zellij defaults.

// ---------------------------------------------------------------------------
// General Options
// ---------------------------------------------------------------------------

// Choose what to do when zellij receives SIGTERM, SIGINT, SIGQUIT or SIGHUP
// eg. when terminal window with an active zellij session is closed
// Options:
//   - detach (Default)
//   - quit
//
// on_force_close "quit"

// Send a request for a simplified ui (without arrow fonts) to plugins
// Options:
//   - true
//   - false (Default)
//
// simplified_ui true

// Choose the path to the default shell that zellij will use for opening new panes
// Default: $SHELL
//
// default_shell "fish"

// Toggle between having pane frames around the panes
// Options:
//   - true (default)
//   - false
//
// pane_frames true

// The name of the default layout to load on startup
// Default: "default"
//
// default_layout "compact"

// Choose the mode that zellij uses when starting up.
// Default: normal
// Set to "locked" so all keystrokes pass through to the terminal by default.
// Press Ctrl+g to enter Normal mode and access Zellij commands.
//
default_mode "locked"

// Toggle enabling the mouse mode.
// On certain configurations, or terminals this could
// potentially interfere with copying text.
// Options:
//   - true (default)
//   - false
//
// mouse_mode false

// Configure the scroll back buffer size
// This is the number of lines zellij stores for each pane in the scroll back
// buffer. Excess number of lines are discarded in a FIFO fashion.
// Valid values: positive integers
// Default value: 10000
//
// scroll_buffer_size 10000

// Provide a command to execute when copying text. The text will be piped to
// the stdin of the program to perform the copy. This can be used with
// terminal emulators which do not support the OSC 52 ANSI control sequence
// that will be used by default if this option is not set.
// Examples:
//
// copy_command "xclip -selection clipboard" // x11
// copy_command "wl-copy"                    // wayland
// copy_command "pbcopy"                     // osx

// Choose the destination for copied text
// Allows using the primary selection buffer (on x11/wayland) instead of the system clipboard.
// Does not apply when using copy_command.
// Options:
//   - system (default)
//   - primary
//
// copy_clipboard "primary"

// Enable or disable automatic copy (and clear) of selection when releasing mouse
// Default: true
//
// copy_on_select false

// Path to the default editor to use to edit pane scrollbuffer
// Default: $EDITOR or $VISUAL
//
// scrollback_editor "/usr/bin/vim"

// When attaching to an existing session with other users,
// should the session be mirrored (true)
// or should each user have their own cursor (false)
// Default: false
//
// mirror_session true

// The folder in which Zellij will look for layouts
//
layouts

// ---------------------------------------------------------------------------
// Theme: Gruvbox-Material Hard Dark
// ---------------------------------------------------------------------------
//
// Matches the gruvbox-material-hard-dark colorscheme used in:
//   - Ghostty terminal (gruvbox-material-hard-dark theme)
//   - Neovim lualine (gruvbox-material theme)
//
// Palette reference (gruvbox-material, hard background, material foreground, dark):
//   bg_dim:     #141617  (20  22  23)
//   bg0:        #1d2021  (29  32  33)     main background
//   bg1:        #32302f  (50  48  47)     lighter background
//   bg3:        #45403d  (69  64  61)     UI element background
//   bg5:        #5a524c  (90  82  76)     selection background
//   bg_status3: #504945  (80  73  69)     statusline bg
//   fg0:        #d4be98  (212 190 152)    primary foreground
//   fg1:        #ddc7a1  (221 199 161)    secondary foreground
//   grey0:      #7c6f64  (124 111 100)    dark grey
//   grey1:      #928374  (146 131 116)    medium grey
//   grey2:      #a89984  (168 153 132)    light grey
//   red:        #ea6962  (234 105 98)
//   orange:     #e78a4e  (231 138 78)
//   yellow:     #d8a657  (216 166 87)
//   green:      #a9b665  (169 182 101)
//   aqua:       #89b482  (137 180 130)
//   blue:       #7daea3  (125 174 163)
//   purple:     #d3869b  (211 134 155)

themes {
	gruvbox-dark {
		text_unselected {
			base 212 190 152
			background 29 32 33
			emphasis_0 231 138 78
			emphasis_1 137 180 130
			emphasis_2 169 182 101
			emphasis_3 211 134 155
		}
		text_selected {
			base 212 190 152
			background 50 48 47
			emphasis_0 231 138 78
			emphasis_1 137 180 130
			emphasis_2 169 182 101
			emphasis_3 211 134 155
		}
		ribbon_selected {
			base 29 32 33
			background 169 182 101
			emphasis_0 234 105 98
			emphasis_1 231 138 78
			emphasis_2 211 134 155
			emphasis_3 125 174 163
		}
		ribbon_unselected {
			base 50 48 47
			background 221 199 161
			emphasis_0 234 105 98
			emphasis_1 212 190 152
			emphasis_2 125 174 163
			emphasis_3 211 134 155
		}
		table_title {
			base 169 182 101
			background 29 32 33
			emphasis_0 231 138 78
			emphasis_1 137 180 130
			emphasis_2 169 182 101
			emphasis_3 211 134 155
		}
		table_cell_selected {
			base 212 190 152
			background 69 64 61
			emphasis_0 231 138 78
			emphasis_1 137 180 130
			emphasis_2 169 182 101
			emphasis_3 211 134 155
		}
		table_cell_unselected {
			base 212 190 152
			background 50 48 47
			emphasis_0 231 138 78
			emphasis_1 137 180 130
			emphasis_2 169 182 101
			emphasis_3 211 134 155
		}
		list_selected {
			base 212 190 152
			background 69 64 61
			emphasis_0 231 138 78
			emphasis_1 137 180 130
			emphasis_2 169 182 101
			emphasis_3 211 134 155
		}
		list_unselected {
			base 212 190 152
			background 50 48 47
			emphasis_0 231 138 78
			emphasis_1 137 180 130
			emphasis_2 169 182 101
			emphasis_3 211 134 155
		}
		frame_selected {
			base 169 182 101
			background 29 32 33
			emphasis_0 231 138 78
			emphasis_1 137 180 130
			emphasis_2 211 134 155
			emphasis_3 0
		}
		frame_unselected {
			base 146 131 116
			background 29 32 33
			emphasis_0 231 138 78
			emphasis_1 137 180 130
			emphasis_2 211 134 155
			emphasis_3 0
		}
		frame_highlight {
			base 231 138 78
			background 29 32 33
			emphasis_0 211 134 155
			emphasis_1 216 166 87
			emphasis_2 125 174 163
			emphasis_3 169 182 101
		}
		exit_code_success {
			base 169 182 101
			background 29 32 33
			emphasis_0 137 180 130
			emphasis_1 50 48 47
			emphasis_2 211 134 155
			emphasis_3 125 174 163
		}
		exit_code_error {
			base 234 105 98
			background 29 32 33
			emphasis_0 216 166 87
			emphasis_1 0
			emphasis_2 0
			emphasis_3 0
		}
		multiplayer_user_colors {
			player_1 211 134 155
			player_2 125 174 163
			player_3 234 105 98
			player_4 216 166 87
			player_5 137 180 130
			player_6 231 138 78
			player_7 169 182 101
			player_8 146 131 116
			player_9 0
			player_10 0
		}
	}
}

theme "gruvbox-dark"

// ---------------------------------------------------------------------------
// Keybindings
// ---------------------------------------------------------------------------
//
// Design principles:
//   1. clear-defaults=true -- full control, no surprise Alt bindings
//   2. No Alt/Opt shortcuts -- ALL conflict with EurKEY European chars
//   3. Ctrl+key for mode switches, bare keys within modes
//   4. Vim HJKL navigation everywhere
//   5. Mnemonic action keys (n=new, x=close, s=split, v=vsplit, etc.)
//   6. No Tmux compatibility mode (removed to simplify)
//
// Workflow: Locked -> Ctrl+g -> Normal -> sub-mode -> action -> Normal -> Ctrl+g -> Locked

keybinds clear-defaults=true {

    // -----------------------------------------------------------------------
    // Locked Mode
    // -----------------------------------------------------------------------
    // The default mode. All keystrokes pass through to the terminal.
    // Only Ctrl+g is active to enter Normal mode.
    locked {
        bind "Ctrl g" { SwitchToMode "Normal"; }
    }

    // -----------------------------------------------------------------------
    // Normal Mode
    // -----------------------------------------------------------------------
    // The hub mode. From here, enter sub-modes via Ctrl+key.
    // No mode-specific bindings -- everything is in shared blocks below.
    normal {
    }

    // -----------------------------------------------------------------------
    // Pane Mode (Ctrl+p)
    // -----------------------------------------------------------------------
    // Manage panes: navigate, create, close, float, fullscreen, group.
    // Vim-style: s=split (down), v=vsplit (right), S=stacked.
    pane {
        bind "Ctrl p" { SwitchToMode "Normal"; }
        // Navigation (vim hjkl)
        bind "h" "Left" { MoveFocus "Left"; }
        bind "j" "Down" { MoveFocus "Down"; }
        bind "k" "Up" { MoveFocus "Up"; }
        bind "l" "Right" { MoveFocus "Right"; }
        // Smart navigation: crosses tab boundary at screen edge
        bind "H" { MoveFocusOrTab "Left"; }
        bind "L" { MoveFocusOrTab "Right"; }
        // Pane creation (vim-style splits)
        bind "n" { NewPane; SwitchToMode "Normal"; }
        bind "s" { NewPane "Down"; SwitchToMode "Normal"; }
        bind "v" { NewPane "Right"; SwitchToMode "Normal"; }
        bind "S" { NewPane "stacked"; SwitchToMode "Normal"; }
        // Pane management
        bind "x" { CloseFocus; SwitchToMode "Normal"; }
        bind "f" { ToggleFocusFullscreen; SwitchToMode "Normal"; }
        bind "w" { ToggleFloatingPanes; SwitchToMode "Normal"; }
        bind "e" { TogglePaneEmbedOrFloating; SwitchToMode "Normal"; }
        bind "z" { TogglePaneFrames; SwitchToMode "Normal"; }
        bind "i" { TogglePanePinned; SwitchToMode "Normal"; }
        bind "p" { SwitchFocus; }
        bind "c" { SwitchToMode "RenamePane"; PaneNameInput 0; }
        // Pane groups
        bind "g" { TogglePaneInGroup; }
        bind "G" { ToggleGroupMarking; }
        // Layout cycling (like Amethyst Opt+Cmd+Space)
        bind "Space" { NextSwapLayout; }
    }

    // -----------------------------------------------------------------------
    // Tab Mode (Ctrl+t)
    // -----------------------------------------------------------------------
    // Manage tabs: navigate, create, close, rename, reorder, break panes.
    tab {
        bind "Ctrl t" { SwitchToMode "Normal"; }
        // Navigation (vim hjkl)
        bind "h" "Left" "Up" "k" { GoToPreviousTab; }
        bind "l" "Right" "Down" "j" { GoToNextTab; }
        // Tab management
        bind "n" { NewTab; SwitchToMode "Normal"; }
        bind "x" { CloseTab; SwitchToMode "Normal"; }
        bind "r" { SwitchToMode "RenameTab"; TabNameInput 0; }
        bind "s" { ToggleActiveSyncTab; SwitchToMode "Normal"; }
        // Break pane out of tab
        bind "b" { BreakPane; SwitchToMode "Normal"; }
        bind "]" { BreakPaneRight; SwitchToMode "Normal"; }
        bind "[" { BreakPaneLeft; SwitchToMode "Normal"; }
        // Reorder tabs (vim-like < and >)
        bind "<" { MoveTab "Left"; }
        bind ">" { MoveTab "Right"; }
        // Direct tab access
        bind "1" { GoToTab 1; SwitchToMode "Normal"; }
        bind "2" { GoToTab 2; SwitchToMode "Normal"; }
        bind "3" { GoToTab 3; SwitchToMode "Normal"; }
        bind "4" { GoToTab 4; SwitchToMode "Normal"; }
        bind "5" { GoToTab 5; SwitchToMode "Normal"; }
        bind "6" { GoToTab 6; SwitchToMode "Normal"; }
        bind "7" { GoToTab 7; SwitchToMode "Normal"; }
        bind "8" { GoToTab 8; SwitchToMode "Normal"; }
        bind "9" { GoToTab 9; SwitchToMode "Normal"; }
        // Toggle last tab (like vim Ctrl+^)
        bind "Tab" { ToggleTab; }
    }

    // -----------------------------------------------------------------------
    // Resize Mode (Ctrl+r)
    // -----------------------------------------------------------------------
    // Resize panes. hjkl = increase, HJKL = decrease.
    resize {
        bind "Ctrl r" { SwitchToMode "Normal"; }
        // Increase in direction (vim hjkl)
        bind "h" "Left" { Resize "Increase Left"; }
        bind "j" "Down" { Resize "Increase Down"; }
        bind "k" "Up" { Resize "Increase Up"; }
        bind "l" "Right" { Resize "Increase Right"; }
        // Decrease in direction (uppercase = opposite)
        bind "H" { Resize "Decrease Left"; }
        bind "J" { Resize "Decrease Down"; }
        bind "K" { Resize "Decrease Up"; }
        bind "L" { Resize "Decrease Right"; }
        // Uniform resize
        bind "=" "+" { Resize "Increase"; }
        bind "-" { Resize "Decrease"; }
    }

    // -----------------------------------------------------------------------
    // Move Mode (Ctrl+w)
    // -----------------------------------------------------------------------
    // Move panes around. Uses Ctrl+w like vim's Ctrl+w for window operations.
    move {
        bind "Ctrl w" { SwitchToMode "Normal"; }
        // Move pane in direction (vim hjkl, like vim Ctrl+w H/J/K/L)
        bind "h" "Left" { MovePane "Left"; }
        bind "j" "Down" { MovePane "Down"; }
        bind "k" "Up" { MovePane "Up"; }
        bind "l" "Right" { MovePane "Right"; }
        // Cycle pane position
        bind "n" "Tab" { MovePane; }
        bind "p" { MovePaneBackwards; }
    }

    // -----------------------------------------------------------------------
    // Scroll Mode (Ctrl+s)
    // -----------------------------------------------------------------------
    // Scroll through pane history. Full vim-style navigation.
    scroll {
        bind "Ctrl s" { SwitchToMode "Normal"; }
        // Line-by-line (vim j/k)
        bind "j" "Down" { ScrollDown; }
        bind "k" "Up" { ScrollUp; }
        // Half page (vim Ctrl+d / Ctrl+u)
        bind "d" { HalfPageScrollDown; }
        bind "u" { HalfPageScrollUp; }
        // Full page (vim Ctrl+f / Ctrl+b)
        bind "f" "PageDown" { PageScrollDown; }
        bind "b" "PageUp" { PageScrollUp; }
        // Jump to top/bottom (vim gg / G)
        bind "g" { ScrollToTop; }
        bind "G" { ScrollToBottom; }
        // Edit scrollback in $EDITOR
        bind "e" { EditScrollback; SwitchToMode "Normal"; }
        // Enter search (vim /)
        bind "s" "/" { SwitchToMode "EnterSearch"; SearchInput 0; }
    }

    // -----------------------------------------------------------------------
    // EnterSearch Mode (typing the search query)
    // -----------------------------------------------------------------------
    entersearch {
        bind "Enter" { SwitchToMode "Search"; }
        bind "Ctrl c" "Esc" { SwitchToMode "Scroll"; }
    }

    // -----------------------------------------------------------------------
    // Search Mode (navigating search results)
    // -----------------------------------------------------------------------
    // Vim-style: n=next, N=previous (not p like the default).
    search {
        bind "Ctrl s" { SwitchToMode "Normal"; }
        // Search navigation (vim n/N)
        bind "n" { Search "down"; }
        bind "N" { Search "up"; }
        // Scrolling while searching
        bind "j" "Down" { ScrollDown; }
        bind "k" "Up" { ScrollUp; }
        bind "d" { HalfPageScrollDown; }
        bind "u" { HalfPageScrollUp; }
        bind "f" "PageDown" { PageScrollDown; }
        bind "b" "PageUp" { PageScrollUp; }
        // Search options
        bind "c" { SearchToggleOption "CaseSensitivity"; }
        bind "w" { SearchToggleOption "Wrap"; }
        bind "o" { SearchToggleOption "WholeWord"; }
        // Back to scroll mode (not normal -- preserve scroll position)
        bind "Esc" { SwitchToMode "Scroll"; }
    }

    // -----------------------------------------------------------------------
    // Session Mode (Ctrl+o)
    // -----------------------------------------------------------------------
    // Session management, plugins, and system toggles.
    session {
        bind "Ctrl o" { SwitchToMode "Normal"; }
        bind "d" { Detach; }
        bind "m" { ToggleMouseMode; }
        bind "w" {
            LaunchOrFocusPlugin "session-manager" {
                floating true
                move_to_focused_tab true
            };
            SwitchToMode "Normal"
        }
        bind "c" {
            LaunchOrFocusPlugin "configuration" {
                floating true
                move_to_focused_tab true
            };
            SwitchToMode "Normal"
        }
        bind "p" {
            LaunchOrFocusPlugin "plugin-manager" {
                floating true
                move_to_focused_tab true
            };
            SwitchToMode "Normal"
        }
        bind "l" {
            LaunchOrFocusPlugin "zellij:layout-manager" {
                floating true
                move_to_focused_tab true
            };
            SwitchToMode "Normal"
        }
    }

    // -----------------------------------------------------------------------
    // Rename Modes
    // -----------------------------------------------------------------------
    renametab {
        bind "Ctrl c" { SwitchToMode "Normal"; }
        bind "Esc" { UndoRenameTab; SwitchToMode "Tab"; }
    }
    renamepane {
        bind "Ctrl c" { SwitchToMode "Normal"; }
        bind "Esc" { UndoRenamePane; SwitchToMode "Pane"; }
    }

    // -----------------------------------------------------------------------
    // Shared Bindings
    // -----------------------------------------------------------------------

    // Available in ALL modes except Locked: toggle back to Locked, and Quit.
    shared_except "locked" {
        bind "Ctrl g" { SwitchToMode "Locked"; }
        bind "Ctrl q" { Quit; }
    }

    // All sub-modes (not Normal, not Locked): Esc/Enter returns to Normal.
    // Note: Search mode overrides Esc to go to Scroll instead.
    shared_except "normal" "locked" "entersearch" "search" "renametab" "renamepane" {
        bind "Enter" "Esc" { SwitchToMode "Normal"; }
    }

    // Mode-switch shortcuts: available everywhere except Locked and the target mode.
    shared_except "pane" "locked" {
        bind "Ctrl p" { SwitchToMode "Pane"; }
    }
    shared_except "tab" "locked" {
        bind "Ctrl t" { SwitchToMode "Tab"; }
    }
    shared_except "resize" "locked" {
        bind "Ctrl r" { SwitchToMode "Resize"; }
    }
    shared_except "scroll" "locked" "entersearch" "search" {
        bind "Ctrl s" { SwitchToMode "Scroll"; }
    }
    shared_except "move" "locked" {
        bind "Ctrl w" { SwitchToMode "Move"; }
    }
    shared_except "session" "locked" {
        bind "Ctrl o" { SwitchToMode "Session"; }
    }
}
